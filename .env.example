# Agnes AI Supply Chain Manager — Environment Variables
# Copy this file to .env and fill in your values before running.

# Google Cloud project ID
GCP_PROJECT=your-gcp-project-id

# BigQuery dataset names
BQ_BOM_DATASET=agnes_bom
BQ_ENRICHMENT_DATASET=agnes_enrichment

# Apify web scraping
APIFY_API_TOKEN=your-apify-api-token

# Google Document AI processor
DOCUMENT_AI_PROCESSOR_ID=your-document-ai-processor-id

# ElevenLabs text-to-speech
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id

# Vertex AI location
VERTEX_AI_LOCATION=us-central1

# Gemini API key — powers cognee LLM + embeddings via litellm.
# Get yours free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# cognee configuration
COGNEE_DB_PATH=./cognee_db
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
LLM_API_KEY=your-gemini-api-key
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_API_KEY=your-gemini-api-key

# cognee Cloud API key (from platform.cognee.ai)
COGNEE_API_KEY=your-cognee-api-key

# Agnes FastAPI base URL (local dev only)
AGNES_FASTAPI_URL=http://localhost:8000
